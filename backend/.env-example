CHAT_API_BASE_URL=
CHAT_API_PATH=/v1/chat/completions
CHAT_API_KEY=your_api_key_here
CHAT_API_AUTH_HEADER=Authorization
CHAT_API_AUTH_PREFIX=Bearer
CHAT_MODEL=nvidia/Gemma-4-26B-A4B-NVFP4
CHAT_TEMPERATURE=0
CHAT_API_STREAM=true
CHAT_API_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0.0.0 Safari/537.36
CHAT_API_EXTRA_HEADERS={}
CHAT_API_CONNECT_TIMEOUT_SECONDS=10
CHAT_API_READ_TIMEOUT_SECONDS=120
CHAT_API_MAX_RETRIES=5
CHAT_API_RETRY_BACKOFF_SECONDS=20
CHAT_API_RETRY_STATUS_CODES=429,500,502,503,504
GRAPHDB_URL=http://graphdb:7200
GRAPHDB_REPOSITORY=VDT
GRAPHDB_QUERY_TIMEOUT_SECONDS=120
GRAPHDB_QUERY_MAX_ATTEMPTS=3
GRAPHDB_QUERY_RETRY_DELAY_SECONDS=10
SPARQL_AGENT_MAX_ATTEMPTS=3
QUESTION_TIMEOUT_SECONDS=1200
QUESTION_FINALIZATION_RESERVE_SECONDS=240
LLM_HISTORY_MAX_CHARS=50000
LLM_HISTORY_FIELD_MAX_CHARS=8000
FRONTEND_ORIGIN=http://localhost:5173
ONTOLOGY_SCHEMA_PATH=/app/Ontology/ontology--DEV_type=parsed_sorted.nt
ONTOLOGY_RAG_ENABLED=true
ONTOLOGY_RAG_TOP_K=8
ONTOLOGY_LOOKUP_ENABLED=true
ONTOLOGY_LOOKUP_DB_PATH=/app/Ontology/normalized/embedding_lookup.sqlite
ONTOLOGY_LOOKUP_DOCUMENTS_PATH=/app/Ontology/normalized/embedding_documents.jsonl
ONTOLOGY_LOOKUP_QUERY_COUNT=10
ONTOLOGY_LOOKUP_PER_QUERY_LIMIT=3
EMBEDDING_API_BASE_URL=http://embedding.llm.mobifone.vn
EMBEDDING_API_PATH=/v1/embeddings
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
EMBEDDING_OUTPUT_DIMENSIONS=1024
EMBEDDING_SEND_DIMENSIONS=false
EMBEDDING_API_KEY=
